}

resource "aws_iam_policy" "api_gateway_sqs" {
  name        = "${local.name}-api-gateway-sqs"
  description = "Permite que API Gateway envie mensagens para a fila de geracao de boleto."

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Effect = "Allow"
      Action = [
        "sqs:SendMessage"
      ]
      Resource = aws_sqs_queue.boleto_generation.arn
    }]
  })

  tags = local.common_tags
}

resource "aws_iam_role_policy_attachment" "api_gateway_sqs" {
  role       = aws_iam_role.api_gateway_sqs.name
  policy_arn = aws_iam_policy.api_gateway_sqs.arn
}

                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_4" value="4a. INSERT boleto" style="endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="outbox_usecase" target="outbox_boleto_table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_5" value="4b. INSERT outbox PENDING" style="endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="outbox_adapter" target="outbox_event_table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_6" value="5. COMMIT único" style="endArrow=none;strokeColor=#4f46e5;strokeWidth=2;dashed=1;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="outbox_boleto_table" target="outbox_event_table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_7" value="6. polling PENDING" style="endArrow=block;endFill=1;strokeColor=#445566;strokeWidth=2;fontSize=10;fontColor=#445566;labelBackgroundColor=#ffffff;" parent="1" source="outbox_event_table" target="outbox_worker" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_8" value="7. publish boleto.gerado" style="endArrow=block;endFill=1;strokeColor=#db2777;strokeWidth=2.2;fontSize=10;fontColor=#db2777;labelBackgroundColor=#ffffff;" parent="1" source="outbox_worker" target="outbox_kafka" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_9" value="8. consume" style="endArrow=block;endFill=1;strokeColor=#17865a;strokeWidth=2;fontSize=10;fontColor=#17865a;labelBackgroundColor=#ffffff;" parent="1" source="outbox_kafka" target="outbox_consumers" edge="1">
                    <mxGeometry relative="1" as="geometry"/>

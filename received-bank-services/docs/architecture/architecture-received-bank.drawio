                    <mxGeometry x="40" y="210" width="170" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_usecase" value="&lt;b&gt;CriarBoletoUseCase&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;@Transactional&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#FF9900;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="320" y="205" width="185" height="82" as="geometry"/>

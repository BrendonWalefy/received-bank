                    <mxGeometry x="575" y="275" width="230" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_tx" value="&lt;b&gt;PostgreSQL — mesma transação ACID&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=32;fillColor=#eef2ff;strokeColor=#4f46e5;strokeWidth=1.4;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="335" y="560" width="540" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_boleto_table" value="&lt;b&gt;boletos&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;registro transacional&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f46e5;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="outbox_tx" vertex="1">
                    <mxGeometry x="35" y="70" width="190" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_event_table" value="&lt;b&gt;outbox_events&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;event_type = boleto.gerado&lt;br/&gt;status = PENDING&lt;br/&gt;attempts = 0&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f46e5;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="outbox_tx" vertex="1">
                    <mxGeometry x="300" y="54" width="205" height="112" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_worker" value="&lt;b&gt;OutboxKafkaPublisher&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;@Scheduled a cada 5s&lt;br/&gt;busca até 50 PENDING&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=1.6;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1070" y="265" width="230" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_kafka" value="&lt;b&gt;Kafka / MSK&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;tópico boleto.gerado&lt;br/&gt;key = boletoId&lt;/span&gt;" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff1f8;strokeColor=#db2777;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="246" width="210" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_consumers" value="&lt;b&gt;Consumidores&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;payment-service&lt;br/&gt;query-service&lt;br/&gt;notification-service&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fff9;strokeColor=#17865a;strokeWidth=1.4;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="455" width="210" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_status_published" value="&lt;b&gt;Sucesso&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;Kafka confirma em até 10s&lt;br/&gt;status = PUBLISHED&lt;br/&gt;published_at preenchido&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fff9;strokeColor=#17865a;strokeWidth=1.4;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1045" y="610" width="250" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_status_failed" value="&lt;b&gt;Falha controlada&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;attempts + 1&lt;br/&gt;last_error gravado&lt;br/&gt;após max-attempts: FAILED&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#be123c;strokeWidth=1.4;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1335" y="610" width="250" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_note_1" value="&lt;b&gt;Por que existe?&lt;/b&gt;&lt;br/&gt;Evita dual write: banco e Kafka não compartilham transação. O evento fica durável no PostgreSQL antes da publicação assíncrona." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#b7791f;strokeWidth=1.2;align=left;verticalAlign=top;spacing=12;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="835" width="365" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_note_2" value="&lt;b&gt;Semântica real&lt;/b&gt;&lt;br/&gt;O fluxo entrega at-least-once. Se publicar no Kafka e cair antes de marcar PUBLISHED, o evento pode sair duplicado. Consumidores precisam ser idempotentes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#2563a8;strokeWidth=1.2;align=left;verticalAlign=top;spacing=12;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="430" y="835" width="410" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_note_3" value="&lt;b&gt;Evolução produção&lt;/b&gt;&lt;br/&gt;Adicionar PROCESSING, lock/SELECT FOR UPDATE SKIP LOCKED, backoff, reprocessamento de FAILED, métricas e limpeza periódica da tabela." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fff9;strokeColor=#17865a;strokeWidth=1.2;align=left;verticalAlign=top;spacing=12;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="865" y="835" width="445" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_note_4" value="&lt;b&gt;No código atual&lt;/b&gt;&lt;br/&gt;Busca apenas PENDING. Ao atingir max-attempts, o evento vira FAILED e deixa de ser republicado automaticamente." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#be123c;strokeWidth=1.2;align=left;verticalAlign=top;spacing=12;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1335" y="835" width="395" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_1" value="1. cria boleto" style="endArrow=block;endFill=1;strokeColor=#445566;strokeWidth=2;fontSize=10;fontColor=#445566;labelBackgroundColor=#ffffff;" parent="1" source="outbox_actor" target="outbox_usecase" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_2" value="2. cria agregado" style="endArrow=block;endFill=1;strokeColor=#445566;strokeWidth=2;fontSize=10;fontColor=#445566;labelBackgroundColor=#ffffff;" parent="1" source="outbox_usecase" target="outbox_domain" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_3" value="3. evento de domínio" style="endArrow=block;endFill=1;strokeColor=#445566;strokeWidth=2;fontSize=10;fontColor=#445566;labelBackgroundColor=#ffffff;" parent="1" source="outbox_domain" target="outbox_adapter" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_4" value="4a. INSERT boleto" style="endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="outbox_usecase" target="outbox_boleto_table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_5" value="4b. INSERT outbox PENDING" style="endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="outbox_adapter" target="outbox_event_table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_6" value="5. COMMIT único" style="endArrow=none;strokeColor=#4f46e5;strokeWidth=2;dashed=1;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="outbox_boleto_table" target="outbox_event_table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_7" value="6. polling PENDING" style="endArrow=block;endFill=1;strokeColor=#445566;strokeWidth=2;fontSize=10;fontColor=#445566;labelBackgroundColor=#ffffff;" parent="1" source="outbox_event_table" target="outbox_worker" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_8" value="7. publish boleto.gerado" style="endArrow=block;endFill=1;strokeColor=#db2777;strokeWidth=2.2;fontSize=10;fontColor=#db2777;labelBackgroundColor=#ffffff;" parent="1" source="outbox_worker" target="outbox_kafka" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_9" value="8. consume" style="endArrow=block;endFill=1;strokeColor=#17865a;strokeWidth=2;fontSize=10;fontColor=#17865a;labelBackgroundColor=#ffffff;" parent="1" source="outbox_kafka" target="outbox_consumers" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_10" value="confirmação Kafka" style="endArrow=block;endFill=1;strokeColor=#17865a;strokeWidth=2;fontSize=10;fontColor=#17865a;labelBackgroundColor=#ffffff;" parent="1" source="outbox_worker" target="outbox_status_published" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outbox_edge_11" value="timeout / broker fora / payload inválido" style="endArrow=block;endFill=1;strokeColor=#be123c;strokeWidth=2;fontSize=10;fontColor=#be123c;labelBackgroundColor=#ffffff;" parent="1" source="outbox_worker" target="outbox_status_failed" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="persistent-idempotency-flow" name="Idempotência Persistente">
        <mxGraphModel dx="509" dy="827" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="idem_title" value="&lt;b style=&quot;font-size:22px;&quot;&gt;Received Bank — Idempotência Persistente nos Consumers&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="40" y="24" width="1100" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="idem_subtitle" value="Como cada bounded context evita processar o mesmo evento mais de uma vez sem depender da outbox do boleto-service." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontColor=#545B64;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="1200" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="idem_why" value="&lt;b&gt;Por que isso existe?&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Kafka e Transactional Outbox entregam eventos com semântica &lt;b&gt;at-least-once&lt;/b&gt;. Isso protege contra perda, mas permite duplicidade em crash, retry, rebalance ou reprocessamento operacional.&lt;br/&gt;&lt;br/&gt;A solução é tornar cada consumidor idempotente usando o &lt;b&gt;eventId&lt;/b&gt; como chave de controle local." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#b7791f;strokeWidth=1.5;align=left;verticalAlign=top;spacing=14;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="120" width="335" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="idem_event_bus" value="&lt;b&gt;Kafka / MSK&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;boleto.gerado&lt;br/&gt;pagamento.efetivado&lt;br/&gt;pagamento.rejeitado&lt;br/&gt;notificacao.enviada&lt;/span&gt;" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff1f8;strokeColor=#db2777;strokeWidth=1.6;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="455" y="170" width="210" height="138" as="geometry"/>
                </mxCell>
                <mxCell id="idem_consumer_payment" value="&lt;b&gt;payment-service&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;consumer: boleto.gerado&lt;br/&gt;efeito: registra boleto aguardando pagamento&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=1.4;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="780" y="120" width="260" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="idem_consumer_query" value="&lt;b&gt;query-service&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;consumers: boleto / pagamento / notificação&lt;br/&gt;efeito: atualiza read model CQRS&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=1.4;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="780" y="250" width="260" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="idem_consumer_notification" value="&lt;b&gt;notification-service&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;consumers: boleto / pagamento&lt;br/&gt;efeito: envia notificação e publica notificacao.enviada&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=1.4;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="780" y="380" width="260" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="idem_registry" value="&lt;b&gt;ProcessedEventRegistry&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;componente compartilhado em commons-infra&lt;br/&gt;controla consumer_name + event_id&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#2563a8;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1125" y="244" width="260" height="94" as="geometry"/>
                </mxCell>
                <mxCell id="idem_db_boundary" value="&lt;b&gt;Storage local por bounded context&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=34;fillColor=#eef2ff;strokeColor=#4f46e5;strokeWidth=1.5;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1450" y="120" width="300" height="352" as="geometry"/>
                </mxCell>
                <mxCell id="idem_table_payment" value="&lt;b&gt;recebimentos_payment&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;processed_events&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f46e5;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="idem_db_boundary" vertex="1">
                    <mxGeometry x="35" y="60" width="230" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="idem_table_query" value="&lt;b&gt;recebimentos_query&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;processed_events&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f46e5;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="idem_db_boundary" vertex="1">
                    <mxGeometry x="35" y="150" width="230" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="idem_table_notification" value="&lt;b&gt;recebimentos_notification&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;processed_events&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4f46e5;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="idem_db_boundary" vertex="1">
                    <mxGeometry x="35" y="240" width="230" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="idem_flow_title" value="&lt;b&gt;Ciclo de decisão por evento&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=16;fontColor=#172033;" parent="1" vertex="1">
                    <mxGeometry x="40" y="545" width="420" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="idem_step_1" value="&lt;b&gt;1. Evento chega&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;consumer recebe payload com eventId&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="590" width="210" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="idem_step_2" value="&lt;b&gt;2. Tenta registrar&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;INSERT processed_events&lt;br/&gt;status = PROCESSING&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef6ff;strokeColor=#2563a8;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="305" y="590" width="230" height="86" as="geometry"/>
                </mxCell>
                <mxCell id="idem_step_3" value="&lt;b&gt;3a. Novo evento&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;executa efeito local&lt;br/&gt;marca PROCESSED&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fff9;strokeColor=#17865a;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="610" y="548" width="220" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="idem_step_4" value="&lt;b&gt;3b. Já PROCESSED&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;ignora duplicata&lt;br/&gt;não repete efeito&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8ea;strokeColor=#b7791f;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="610" y="682" width="220" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="idem_step_5" value="&lt;b&gt;3c. PROCESSING recente&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;falha para Kafka tentar depois&lt;br/&gt;evita efeito concorrente&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#be123c;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="890" y="548" width="240" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="idem_step_6" value="&lt;b&gt;3d. PROCESSING expirado&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;color:#545B64;&quot;&gt;reivindica novamente&lt;br/&gt;protege crash/restart&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4f46e5;strokeWidth=1.2;align=center;verticalAlign=middle;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="890" y="682" width="240" height="92" as="geometry"/>
                </mxCell>
                <mxCell id="idem_ai_box" value="&lt;b&gt;Boa prática com Agents de IA&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Este projeto usa IA como par de engenharia para evoluir arquitetura incrementalmente: entender o domínio, desenhar a solução, implementar padrões, validar com testes e documentar os porquês.&lt;br/&gt;&lt;br/&gt;O objetivo não é só gerar código; é aprender tecnologias modernas e deixar decisões rastreáveis, revisáveis e explicáveis em entrevista ou operação." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7fff9;strokeColor=#17865a;strokeWidth=1.5;align=left;verticalAlign=top;spacing=14;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1235" y="560" width="515" height="214" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_1" value="entrega at-least-once" style="endArrow=block;endFill=1;strokeColor=#db2777;strokeWidth=2;fontSize=10;fontColor=#db2777;labelBackgroundColor=#ffffff;" parent="1" source="idem_event_bus" target="idem_consumer_payment" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_2" value="entrega at-least-once" style="endArrow=block;endFill=1;strokeColor=#db2777;strokeWidth=2;fontSize=10;fontColor=#db2777;labelBackgroundColor=#ffffff;" parent="1" source="idem_event_bus" target="idem_consumer_query" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_3" value="entrega at-least-once" style="endArrow=block;endFill=1;strokeColor=#db2777;strokeWidth=2;fontSize=10;fontColor=#db2777;labelBackgroundColor=#ffffff;" parent="1" source="idem_event_bus" target="idem_consumer_notification" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_4" value="verifica eventId" style="endArrow=block;endFill=1;strokeColor=#2563a8;strokeWidth=2;fontSize=10;fontColor=#2563a8;labelBackgroundColor=#ffffff;" parent="1" source="idem_consumer_query" target="idem_registry" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_5" value="persistência local" style="endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="idem_registry" target="idem_db_boundary" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_6" value="" style="endArrow=block;endFill=1;strokeColor=#445566;strokeWidth=2;" parent="1" source="idem_step_1" target="idem_step_2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_7" value="insert ok" style="endArrow=block;endFill=1;strokeColor=#17865a;strokeWidth=2;fontSize=10;fontColor=#17865a;labelBackgroundColor=#ffffff;" parent="1" source="idem_step_2" target="idem_step_3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_8" value="duplicata" style="endArrow=block;endFill=1;strokeColor=#b7791f;strokeWidth=2;fontSize=10;fontColor=#b7791f;labelBackgroundColor=#ffffff;" parent="1" source="idem_step_2" target="idem_step_4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_9" value="ainda em andamento" style="endArrow=block;endFill=1;strokeColor=#be123c;strokeWidth=2;fontSize=10;fontColor=#be123c;labelBackgroundColor=#ffffff;" parent="1" source="idem_step_2" target="idem_step_5" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="idem_edge_10" value="timeout" style="endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;fontSize=10;fontColor=#4f46e5;labelBackgroundColor=#ffffff;" parent="1" source="idem_step_2" target="idem_step_6" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
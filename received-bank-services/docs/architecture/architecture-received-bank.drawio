                <mxCell id="outbox_edge_10" value="confirmação Kafka" style="endArrow=block;endFill=1;strokeColor=#17865a;strokeWidth=2;fontSize=10;fontColor=#17865a;labelBackgroundColor=#ffffff;" parent="1" source="outbox_worker" target="outbox_status_published" edge="1">
                    <mxGeometry relative="1" as="geometry"/>

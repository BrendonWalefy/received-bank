                <mxCell id="outbox_subtitle" value="Como o boleto e o evento &lt;b&gt;boleto.gerado&lt;/b&gt; nascem na mesma transação e são publicados depois, sem dual write direto entre PostgreSQL e Kafka." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=13;fontColor=#545B64;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="1250" height="28" as="geometry"/>
                </mxCell>

                <mxCell id="outbox_boundary_core" value="" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;opacity=45;strokeColor=#2154FF;strokeWidth=2;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="275" y="105" width="720" height="390" as="geometry"/>
